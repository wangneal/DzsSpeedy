{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenSpeedy",
  "version": "3.2.0",
  "identifier": "com.game1024.openspeedy",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenSpeedy",
        "width": 960,
        "height": 640,
        "minWidth": 480,
        "minHeight": 360,
        "decorations": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    },
    "resources": {
      "binaries/*": "./"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
